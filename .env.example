# Copy this file to .env.local and fill in the values.
# Never commit .env.local — it's already in .gitignore.

# ── Database (Supabase) ──────────────────────────────────────────────────────
# From: supabase.com/dashboard → your project → Connect → Server tab
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SECRET_KEY=sb_secret_...

# ── Auth session secret ──────────────────────────────────────────────────────
# Any random 32+ char string: openssl rand -hex 32
SESSION_SECRET=

# ── Email (Resend) ───────────────────────────────────────────────────────────
# From: resend.com → API Keys
RESEND_API_KEY=re_...
FROM_EMAIL=noreply@yourdomain.com

# ── Figma OAuth ──────────────────────────────────────────────────────────────
# From: figma.com/developers → your app
FIGMA_CLIENT_ID=
FIGMA_CLIENT_SECRET=

# ── GitHub OAuth ─────────────────────────────────────────────────────────────
# From: github.com → Settings → Developer settings → OAuth Apps
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Stripe ───────────────────────────────────────────────────────────────────
# From: dashboard.stripe.com → Developers → API keys / Webhooks / Products
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_MONITORING_PRICE_ID=price_...

# ── AI (Anthropic) ───────────────────────────────────────────────────────────
# From: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# ── Vercel KV (rate limiting) ────────────────────────────────────────────────
# From: Vercel dashboard → Storage → KV → your store → .env.local tab
KV_REST_API_URL=

# ── Cron auth (Vercel cron jobs) ─────────────────────────────────────────────
# Any secret string — must match CRON_SECRET in Vercel env vars
CRON_SECRET=
